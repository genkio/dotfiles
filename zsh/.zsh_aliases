alias vmise='mise use $(jq -r ".volta | to_entries[] | \"\(.key)@\(.value)\"" package.json)'
alias y="yazi"
cc() {
  local -a pre
  if [[ "$1" == "-em" ]]; then
    pre=(--effort max)
    shift
  fi
  if [[ $# -eq 0 ]]; then
    claude "${pre[@]}"
  elif [[ "$1" == -* ]]; then
    claude "${pre[@]}" "$@"
  else
    claude "${pre[@]}" -n "$*"
  fi
}
alias ccx="claude --dangerously-skip-permissions"
alias cx="codex"
alias cxx="codex --dangerously-bypass-approvals-and-sandbox"

lg() {
  vi . -c "lua vim.defer_fn(require('config.lazygit').open_quit_all, 50)"
}
alias ld="lazydocker"

# lazysql launcher with docker auto-discovery.
#   lq             in a repo -> find its dockerized DBs, pick one, connect
#   lq -r          same, read-only
#   lq <url|flags> pass straight through to lazysql
# host:port come from each container's live published binding, so non-default
# hosts (e.g. a sandbox IP override in some .env) resolve right - nothing hardcoded.
# No DB container for the repo? fall back to a sqlite file found in the tree.
lq() {
  local -a pre
  if [[ "$1" == "-r" || "$1" == "--read-only" ]]; then
    pre+=(--read-only)
    shift
  fi
  if (( $# > 0 )); then
    lazysql "${pre[@]}" "$@"
    return
  fi

  if ! command -v docker >/dev/null 2>&1; then
    echo "lq: docker not found" >&2
    return 1
  fi
  local ids_raw
  if ! ids_raw="$(docker ps -q 2>/dev/null)"; then
    echo "lq: cannot talk to docker (is the daemon running?)" >&2
    return 1
  fi

  local repo
  repo="$(git rev-parse --show-toplevel 2>/dev/null)" || repo="$PWD"

  # image -> driver, live binding -> host:port, env -> creds; emit "label<TAB>url"
  local prog='def val($env; $k): ($env | map(select(startswith($k + "="))) | (.[0] // "") | sub("^[^=]+=";""));
.[]
| ((.Config.Image // "") | ascii_downcase) as $img
| (if   ($img|test("postgres|postgis"))          then {drv:"postgres",port:5432}
   elif ($img|test("mysql|mariadb|percona"))     then {drv:"mysql",port:3306}
   elif ($img|test("mssql|sqlserver|azure-sql")) then {drv:"mssql",port:1433}
   else null end) as $d
| select($d != null)
| { env:   (.Config.Env // []),
    ports: (.NetworkSettings.Ports // {}),
    svc:   ((.Config.Labels["com.docker.compose.service"]) // ((.Name // "") | ltrimstr("/"))),
    wd:    (.Config.Labels["com.docker.compose.project.working_dir"] // "") } as $c0
| select($c0.wd == $repo or ($c0.wd | startswith($repo + "/")))
| (($d.port|tostring) + "/tcp") as $pkey
| (($c0.ports[$pkey]) // []) as $primary
| (if ($primary|length) > 0 then $primary
   else ($c0.ports | to_entries | map(select(.key | endswith("/tcp")) | .value) | map(select(. != null)) | add // [])
   end) as $binds
| ($binds | map(select(.HostPort != null and .HostPort != ""))) as $valid
| select(($valid|length) > 0)
| (($valid | map(select((.HostIp // "") | test(":") | not))) as $v4
   | (if ($v4|length) > 0 then $v4[0] else $valid[0] end)) as $b
| ($b.HostPort) as $port
| (($b.HostIp // "")) as $hip
| (if $hip == "" or $hip == "0.0.0.0" or $hip == "::" then "127.0.0.1" else $hip end) as $host
| (if $d.drv == "postgres" then
     (val($c0.env;"POSTGRES_USER") | if . == "" then "postgres" else . end) as $u
     | {u:$u, p: val($c0.env;"POSTGRES_PASSWORD"), db: (val($c0.env;"POSTGRES_DB") | if . == "" then $u else . end)}
   elif $d.drv == "mysql" then
     (if val($c0.env;"MYSQL_USER") != "" then {u: val($c0.env;"MYSQL_USER"), p: val($c0.env;"MYSQL_PASSWORD")}
      else {u:"root", p: val($c0.env;"MYSQL_ROOT_PASSWORD")} end) + {db: val($c0.env;"MYSQL_DATABASE")}
   else
     {u:"sa", db:"", p: (val($c0.env;"MSSQL_SA_PASSWORD") | if . == "" then val($c0.env;"SA_PASSWORD") else . end)}
   end) as $c
| ($c.u|@uri) as $eu | ($c.p|@uri) as $ep
| (if $d.drv == "postgres" then "postgres://\($eu):\($ep)@\($host):\($port)/\($c.db)?sslmode=disable"
   elif $d.drv == "mysql"  then "mysql://\($eu):\($ep)@\($host):\($port)/\($c.db)"
   else "sqlserver://\($eu):\($ep)@\($host):\($port)/\($c.db)" end) as $url
| "\($c0.svc) | \($d.drv) | \($c.db) | \($host):\($port)\t\($url)"'

  local rows=""
  if [[ -n "$ids_raw" ]]; then
    rows="$(docker inspect "${(@f)ids_raw}" 2>/dev/null | jq -r --arg repo "$repo" "$prog" 2>/dev/null | sort)"
  fi

  if [[ -z "$rows" ]]; then
    local -a sqlite_files
    sqlite_files=(${(f)"$(find "$repo" -maxdepth 4 \( -name node_modules -o -name .git \) -prune -o \
      -type f \( -iname '*.sqlite' -o -iname '*.sqlite3' -o -iname '*.db' -o -iname '*.db3' \) -print 2>/dev/null)"})
    local f
    for f in "${sqlite_files[@]}"; do
      # magic header - rejects non-sqlite files that just share a .db extension
      [[ "$(head -c 15 "$f" 2>/dev/null)" == "SQLite format 3" ]] || continue
      rows+="${f#$repo/} | sqlite | $(du -h "$f" 2>/dev/null | cut -f1)"$'\t'"$f"$'\n'
    done
    rows="${rows%$'\n'}"

    if [[ -z "$rows" ]]; then
      local -a composes
      composes=(${(f)"$(find "$repo" -maxdepth 4 \( -name node_modules -o -name .git \) -prune -o \
        \( -iname 'docker-compose*.yml' -o -iname 'docker-compose*.yaml' \
           -o -iname 'compose*.yml' -o -iname 'compose*.yaml' \) -print 2>/dev/null)"})
      if (( ${#composes} > 0 )); then
        echo "lq: compose file(s) found but no DB container running for this repo." >&2
        echo "    start the stack first (e.g. docker compose up -d), then rerun lq." >&2
        return 1
      fi
      echo "lq: no dockerized DB for this repo - opening lazysql picker" >&2
      lazysql "${pre[@]}"
      return
    fi
    echo "lq: no dockerized DB - loading sqlite file(s) from repo" >&2
  fi

  local line
  if (( $(printf '%s\n' "$rows" | grep -c .) > 1 )); then
    if command -v fzf >/dev/null 2>&1; then
      line="$(printf '%s\n' "$rows" | fzf --delimiter=$'\t' --with-nth=1 --height=40% --reverse \
        --prompt='db> ' --header='lazysql: pick a database')" || return
    else
      local -a disp; disp=("${(@f)rows}")
      local pick PS3="db> "
      select pick in "${disp[@]%%$'\t'*}"; do
        [[ -n "$pick" ]] && { line="${disp[$REPLY]}"; break; }
      done
    fi
  else
    line="$rows"
  fi

  [[ -z "$line" ]] && { echo "lq: nothing selected" >&2; return 1; }
  lazysql "${pre[@]}" "${line##*$'\t'}"
}

_lr_age() {  # $1=epoch -> REPLY: compact age (9s/5m/23h/2d/Jun 25)
  local d=$(( EPOCHSECONDS - $1 ))
  if   (( d < 60 ));     then REPLY="${d}s"
  elif (( d < 3600 ));   then REPLY="$(( d / 60 ))m"
  elif (( d < 86400 ));  then REPLY="$(( d / 3600 ))h"
  elif (( d < 604800 )); then REPLY="$(( d / 86400 ))d"
  else strftime -s REPLY '%b %d' $1
  fi
}

_lr_clean() {  # $1=raw title -> REPLY: one line, trimmed, <=72 chars
  emulate -L zsh
  setopt extended_glob
  local s=${1//$'\n'/ }; s=${s//$'\t'/ }; s=${s//$'\r'/ }
  s=${s##[[:space:]]#}
  s=${s%%[[:space:]]#}
  (( ${#s} > 72 )) && s="${s[1,71]}…"
  REPLY=${s:-'(untitled)'}
}

# List coding-agent sessions started in THIS dir, newest first; Enter resumes.
#   claude -> ~/.claude/projects/<cwd, with / . _ folded to ->/<uuid>.jsonl
#   codex  -> ~/.codex/sessions/**/rollout-*-<uuid>.jsonl (cwd in the header)
# Titles (claude aiTitle, codex first user_message) can sit hundreds of KB into
# the file, so grep -m1 scans it whole: stops at the first hit, no cap needed.
# fzf picker, `select` fallback; needs jq for codex titles.
lr() {
  emulate -L zsh
  setopt local_options extended_glob null_glob
  zmodload zsh/datetime 2>/dev/null   # EPOCHSECONDS, strftime
  zmodload zsh/stat 2>/dev/null       # zstat

  local -a rows st
  local f id title mt age ct disp agent

  local enc=${PWD//\//-}; enc=${enc//./-}; enc=${enc//_/-}
  local cdir=$HOME/.claude/projects/$enc
  if [[ -d $cdir ]]; then
    for f in $cdir/*.jsonl(N.); do
      zstat -A st +mtime "$f" 2>/dev/null || continue; mt=$st[1]
      id=${f:t:r}
      title=$(grep -m1 -o '"aiTitle":"[^"]*"' "$f" 2>/dev/null)
      title=${title#'"aiTitle":"'}; title=${title%'"'}
      _lr_age $mt; age=$REPLY
      _lr_clean "$title"; ct=$REPLY
      agent=claude
      disp="${(r:6:)agent} ${(l:6:)age}  $ct"
      rows+=( "$mt"$'\t'"$disp"$'\t'"$agent"$'\t'"$id" )
    done
  fi

  for f in $HOME/.codex/sessions/**/*.jsonl(N.); do
    head -c 1024 "$f" 2>/dev/null | grep -qF "\"cwd\":\"$PWD\"" || continue
    zstat -A st +mtime "$f" 2>/dev/null || continue; mt=$st[1]
    id=${f:t:r}; id=${id: -36}
    title=$(grep -m1 '"payload":{"type":"user_message"' "$f" 2>/dev/null | jq -r '.payload.message // empty' 2>/dev/null)
    _lr_age $mt; age=$REPLY
    _lr_clean "$title"; ct=$REPLY
    agent=codex
    disp="${(r:6:)agent} ${(l:6:)age}  $ct"
    rows+=( "$mt"$'\t'"$disp"$'\t'"$agent"$'\t'"$id" )
  done

  (( ${#rows} )) || { print -u2 "lr: no Claude or Codex sessions for $PWD"; return 1; }

  local -a lines
  lines=( "${(@f)$(print -rl -- "${rows[@]}" | sort -t$'\t' -k1,1nr | cut -f2-)}" )

  local line
  if (( ${#lines} > 1 )); then
    if (( $+commands[fzf] )); then
      line=$(print -rl -- "${lines[@]}" | fzf --delimiter=$'\t' --with-nth=1 \
        --height=60% --reverse --no-sort --prompt='resume ' \
        --header='claude / codex sessions in this dir · enter resumes') || return
    else
      local pick PS3='resume> '
      select pick in "${lines[@]%%$'\t'*}"; do
        [[ -n $pick ]] && { line=$lines[$REPLY]; break; }
      done
    fi
  else
    line=$lines[1]
  fi
  [[ -n $line ]] || { print -u2 "lr: nothing selected"; return 1; }

  local -a parts=( "${(@ps:\t:)line}" )
  case $parts[2] in
    claude) claude --resume "$parts[3]" ;;
    codex)  codex resume "$parts[3]" ;;
    *) print -u2 "lr: unknown agent '$parts[2]'"; return 1 ;;
  esac
}

alias box="maestral"

zip() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: zip <file-or-folder>"
    return 1
  fi

  local src="${1:A}"
  if [[ ! -e "$src" ]]; then
    echo "zip: path not found: $1"
    return 1
  fi

  local sevenzip="${commands[7zz]:-${commands[7z]}}"
  if [[ -z "$sevenzip" ]]; then
    echo "zip: 7-Zip executable not found"
    return 127
  fi

  local parent="${src:h}"
  local entry="${src:t}"
  local archive="${parent}/${entry}.zip"
  local -a excludes=(
    '-xr!__MACOSX'
    '-xr!.DS_Store'
    '-xr!._*'
    '-xr!.AppleDouble'
    '-xr!.Spotlight-V100'
    '-xr!.Trashes'
    '-xr!.fseventsd'
  )

  if [[ -e "$archive" ]]; then
    echo "zip: archive already exists: $archive"
    return 1
  fi

  (
    cd "$parent" || return
    "$sevenzip" a -tzip -mx=0 "$archive" "$entry" "${excludes[@]}"
  ) || return

  if ! osascript \
    -e 'on run argv' \
    -e 'set trashTarget to POSIX file (item 1 of argv) as alias' \
    -e 'tell application "Finder" to delete trashTarget' \
    -e 'end run' \
    "$src"; then
    echo "zip: archive created but failed to move to Trash: $src"
    return 1
  fi
}

_unzip_archive() {
  local sevenzip="$1"
  local src="${2:A}"
  local parent="${src:h}"
  local entry="${src:t}"
  local base="${entry:r}"

  if [[ ! -f "$src" ]]; then
    echo "unzip: not a file: $src"
    return 1
  fi

  if [[ "${entry:l}" != *.zip ]]; then
    echo "unzip: expected a .zip file: $src"
    return 1
  fi

  local dest="${parent}/${base}"
  if [[ -e "$dest" ]]; then
    echo "unzip: destination already exists: $dest"
    return 1
  fi

  mkdir "$dest" || return
  "$sevenzip" x "$src" "-o$dest" || return
}

unzip() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: unzip <zip-file-or-folder>"
    return 1
  fi

  local src="${1:A}"
  if [[ ! -e "$src" ]]; then
    echo "unzip: path not found: $1"
    return 1
  fi

  local sevenzip="${commands[7zz]:-${commands[7z]}}"
  if [[ -z "$sevenzip" ]]; then
    echo "unzip: 7-Zip executable not found"
    return 127
  fi

  if [[ -d "$src" ]]; then
    local -a raw_archives archives
    local -A seen
    local archive

    raw_archives=("$src"/*.zip(N) "$src"/*.ZIP(N))
    for archive in "${raw_archives[@]}"; do
      [[ -n "${seen[$archive]}" ]] && continue
      seen[$archive]=1
      archives+=("$archive")
    done

    if [[ ${#archives[@]} -eq 0 ]]; then
      echo "unzip: no .zip files found in folder: $1"
      return 1
    fi

    for archive in "${archives[@]}"; do
      _unzip_archive "$sevenzip" "$archive" || return
    done
    return
  fi

  _unzip_archive "$sevenzip" "$src"
}

alias x="clear"
alias xx="exit"
alias ff="fastfetch"
alias ls="eza --group-directories-first"
alias ll="eza --group-directories-first --all -lh"
alias lt="eza --group-directories-first --tree --level=2 --icons"
alias lti="eza --group-directories-first --all --tree --icons"
vi() {
  if [[ $# -gt 0 ]]; then
    nvim "$@"
  else
    nvim .
  fi
}

alias ip="ipconfig getifaddr en0"

killport() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: killport <port>"
    return 1
  fi

  local port="$1"
  if [[ "$port" != <-> || port -lt 1 || port -gt 65535 ]]; then
    echo "killport: invalid port: $port"
    return 1
  fi

  local output
  output="$(lsof -nP -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null)"
  if [[ -z "$output" ]]; then
    echo "killport: no process listening on port $port"
    return 1
  fi

  local -a pids
  pids=("${(@f)output}")
  kill "${pids[@]}" || return

  echo "killport: sent TERM to PID(s): ${pids[*]}"
}

kip() {
  killport "$@"
}

# Copy the last command to clipboard
alias cp1="fc -ln -1 | awk '{\$1=\$1;print}' | pbcopy"
alias txp="tmuxp load -y"
alias txl="tmux ls"
alias src="source ~/.zshrc"
alias his="vi ~/.zsh_history"

TMUX_DEFAULT_SESSION="${TMUX_DEFAULT_SESSION:-tmp}"

tx() {
  if [[ -n "$1" ]]; then
    tmux new -A -s "$1"
  else
    tmux new -A -s "$TMUX_DEFAULT_SESSION"
  fi
}

txk() {
  tmux kill-session -t "${1:-$TMUX_DEFAULT_SESSION}"
}

[[ -f "${${(%):-%N}:A:h}/.zsh_git_aliases" ]] && source "${${(%):-%N}:A:h}/.zsh_git_aliases"

# Tailscale File Send
# Usage: fsend <machine_name> <file1> [file2 ...]
fsend() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: fsend <machine_name> <file1> [file2 ...]"
    return 1
  fi

  local machine="$1"
  shift  # Remove machine from args, leaving only files

  # Tailscale requires a trailing colon after the machine name/IP
  tailscale file cp "$@" "${machine}:"
}

# Tailscale File Get
# Usage: fget [destination_directory]
fget() {
  # Defaults to ~/Downloads/ if no destination is provided
  local dest="${1:-$HOME/Downloads/}"

  echo "Pulling waiting Tailscale files into $dest..."
  tailscale file get "$dest"
}

ltail() {
  if [ $# -eq 0 ]; then
    echo "Usage: ltail <file_or_directory>"
    return 1
  fi
  lnav "$@"
}

# Raise the macOS "control Messages" popover after a cc-imessage upgrade so it can
# be approved, else the first notification silently drops. Via the daemon outbox,
# not `cc-imessage send` (that binds the grant to the terminal, not the daemon).
ccim-ping() {
  local pane="${TMUX_PANE:-%0}"
  python3 -c 'import json,os,sys,time; open(os.path.expanduser("~/.cc-imessage/outbox/%d-ping.json"%time.time_ns()),"w").write(json.dumps({"target":sys.argv[1],"label":"ping","text":"cc-imessage test ping. Reply to confirm inbound routing."})); print("queued for daemon")' "$pane"
  echo "approve the 'control Messages' popover if it appears"
  echo "watch: tail -f /opt/homebrew/var/log/cc-imessage.log   (expect: sent outbox)"
}

# One-word flip of cc-imessage outbound (wraps enable/disable; takes effect on
# the next reply, no daemon restart).
ccim-toggle() {
  if cc-imessage status | grep -q '^outbound: on'; then
    cc-imessage disable
  else
    cc-imessage enable
  fi
}

# pp: pick a saved prompt, choose a coding agent, fill any placeholders, copy the
# finished prompt to the clipboard, then launch the agent empty -- paste (Cmd+V)
# into its composer to review before sending. Agents auto-submit a prompt passed
# as an argument, so we hand it over via the clipboard instead of the CLI.
#   prompts:      ~/.prompt.local, one per line (blank + #comment lines skipped)
#   placeholders: $N:label  -> pp asks "label: " and substitutes every occurrence
#   pp            -> pick, choose agent, fill, copy, launch
#   pp -em        -> claude gets --effort max (ignored for codex/opencode)
#   extra args pass through to the chosen agent (e.g. pp --model opus)
pp() {
  local file="${PROMPT_LOCAL:-$HOME/.prompt.local}"
  [[ -f "$file" ]] || { print -u2 "pp: no prompt file at $file (cp ~/.prompt.local.example \"$file\")"; return 1; }
  command -v fzf >/dev/null || { print -u2 "pp: fzf not found"; return 1; }

  local em=0 a; local -a extra
  for a in "$@"; do [[ "$a" == "-em" ]] && em=1 || extra+=("$a"); done

  local -a prompts
  prompts=("${(@f)$(grep -vE '^[[:space:]]*(#|$)' -- "$file")}")
  (( ${#prompts} )) || { print -u2 "pp: no prompts in $file"; return 1; }

  local -a menu; local i disp
  for i in {1..${#prompts}}; do
    disp="${prompts[i][1,80]}"
    (( ${#prompts[i]} > 80 )) && disp+="…"
    menu+=("$i"$'\t'"$disp")
  done
  local sel
  sel=$(print -rl -- "${menu[@]}" | fzf --delimiter=$'\t' --with-nth='2..' --height=40% --reverse --prompt='prompt> ') || return
  local prompt="${prompts[${sel%%$'\t'*}]}"

  local agent
  agent=$(print -rl -- claude codex opencode | fzf --height=40% --reverse --prompt='agent> ') || return
  [[ -n "$agent" ]] || return

  local -a tokens
  tokens=("${(@f)$(print -r -- "$prompt" | grep -oE '\$[0-9]+:[A-Za-z0-9_-]+' | awk '!seen[$0]++')}")
  local tok val
  for tok in "${tokens[@]}"; do
    [[ -n "$tok" ]] || continue
    val=""
    read "val?${tok#*:}: " || return
    prompt="${prompt//${tok}/${val}}"
  done

  # copy the finished prompt (no trailing newline, so the paste doesn't auto-submit).
  # osc52-copy.sh does pbcopy locally AND emits OSC52 up to the terminal, so this
  # lands on your real clipboard even over ssh; plain pbcopy would hit the remote box.
  local copier="$HOME/dotfiles/tmux/bin/osc52-copy.sh"
  if [[ -x "$copier" ]]; then printf '%s' "$prompt" | "$copier"
  elif command -v pbcopy >/dev/null; then printf '%s' "$prompt" | pbcopy
  elif command -v wl-copy >/dev/null; then printf '%s' "$prompt" | wl-copy
  elif command -v xclip >/dev/null; then printf '%s' "$prompt" | xclip -selection clipboard
  else print -u2 "pp: no clipboard method found"; return 1; fi

  local -a cmd
  case "$agent" in
    claude)   cmd=(claude); (( em )) && cmd+=(--effort max) ;;
    codex)    (( em )) && print -u2 "pp: -em applies to claude only, ignoring"; cmd=(codex) ;;
    opencode) (( em )) && print -u2 "pp: -em applies to claude only, ignoring"; cmd=(opencode) ;;
  esac
  cmd+=("${extra[@]}")
  print -u2 "pp: prompt on clipboard -- paste into ${agent} (Cmd+V), review, then enter"
  "${cmd[@]}"
}
