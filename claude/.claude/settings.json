{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "DISABLE_GROWTHBOOK": "1"
  },
  "permissions": {
    "allow": [
      "Bash(herdlet:*)",
      "Bash(tmux:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)",
      "Edit(~/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5",
  "skillOverrides": {
    "code-review": "user-invocable-only"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-busy.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-busy.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-busy.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-attention.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-idle.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v cc-imessage >/dev/null 2>&1 && cc-imessage notify || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "outputStyle": "Default",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "vim",
  "autoScrollEnabled": false,
  "skipAutoPermissionPrompt": true
}
