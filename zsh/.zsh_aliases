alias vmise='mise use $(jq -r ".volta | to_entries[] | \"\(.key)@\(.value)\"" package.json)'
alias y="yazi"
cc() {
  if [[ $# -eq 0 ]]; then
    claude
  elif [[ "$1" == -* ]]; then
    claude "$@"
  else
    claude -n "$*"
  fi
}
alias ccx="claude --dangerously-skip-permissions"
# claude at max effort. no flag -> current pane; -nh / -nv -> new horizontal / vertical tmux pane.
# a trailing prompt is typed into claude's box but left unsent, so you can edit then hit enter yourself.
#   ccm        ccm 'review this'        ccm -nh        ccm -nv 'review this'
_ccm_fill() {
  local pane="$1" msg="$2" i cap
  # wait for claude's input box, else boot eats the keys. match the /effort hint
  # OR the status meter ("12k/1m") so it still fires after the transient hint
  # clears. bail on a trust prompt - typing there dumps the msg into the dialog.
  for (( i = 0; i < 80; i++ )); do
    cap=$(tmux capture-pane -t "$pane" -p 2>/dev/null)
    [[ "$cap" == *"trust this folder"* ]] && return 1
    print -r -- "$cap" | grep -qE '/effort|[0-9]+k/[0-9]' && break
    sleep 0.25
  done
  sleep 0.3
  tmux send-keys -t "$pane" -l -- "$msg"   # no Enter: leave it for the user to send
}
ccm() {
  local split=
  case "$1" in
    -nh) split=-h; shift ;;
    -nv) split=-v; shift ;;
  esac

  local msg=
  (( $# )) && msg="${(j: :)@}"

  if [[ -z "$split" && -z "$msg" ]]; then
    cc --effort max
    return
  fi

  if [[ -z "$TMUX" ]]; then
    echo "ccm: needs tmux for a new pane or to prefill a prompt" >&2
    return 1
  fi

  if [[ -n "$split" ]]; then
    local new
    new=$(tmux split-window "$split" -t "$TMUX_PANE" -c "#{pane_current_path}" -P -F '#{pane_id}') || return
    ( sleep 1   # fresh pane's line editor isn't up yet; keys sent too early get dropped
      tmux send-keys -t "$new" -l 'cc --effort max'
      tmux send-keys -t "$new" Enter
      [[ -n "$msg" ]] && _ccm_fill "$new" "$msg"
    ) &!
    return
  fi

  # current pane + prefill: fill from a detached job, then take this pane over with claude
  ( _ccm_fill "$TMUX_PANE" "$msg" ) &!
  cc --effort max
}
# no --force, so a dirty worktree is kept (don't destroy uncommitted work) and
# its window held open to finish up.
_cct_cleanup() {
  local wt branch top main
  wt=$(git rev-parse --show-toplevel) || return
  branch=$(git rev-parse --abbrev-ref HEAD)
  top=$(git rev-parse --git-common-dir) || return
  main=${top:A:h}
  builtin cd "$main" 2>/dev/null
  if git worktree remove "$wt" 2>/dev/null; then
    git branch -d "$branch" 2>/dev/null
    return
  fi
  print -P "%F{yellow}cct: worktree kept (uncommitted changes):%f $wt"
  print "git -C ${(q)main} worktree remove --force ${(q)wt} && git -C ${(q)main} branch -d ${(q)branch}"
  builtin cd "$wt" 2>/dev/null
  exec zsh
}
# claude --tmux hangs inside tmux and its worktree cleanup never runs, so drive
# the worktree ourselves and reclaim it when claude exits (see _cct_cleanup).
#   cct my-tree
cct() {
  [[ -n "$TMUX" ]] || { print -u2 "cct: needs tmux"; return 1; }
  local name="$1" top main wt pr= made_wt= made_branch=
  [[ -n "$name" ]] || { print -u2 "cct: usage: cct <name> | cct '#<pr>' | cct <pr-url>"; return 1; }
  top=$(git rev-parse --git-common-dir 2>/dev/null) || { print -u2 "cct: not in a git repo"; return 1; }
  main=${top:A:h}

  if [[ "$name" =~ '^#([0-9]+)$' ]]; then
    pr=$match[1]; name="pr-$pr"
  elif [[ "$name" =~ 'github.*/pull/([0-9]+)' ]]; then
    pr=$match[1]; name="pr-$pr"
  fi
  wt="$main/.claude/worktrees/$name"

  if [[ ! -d "$wt" ]]; then
    if git -C "$main" show-ref --quiet --verify "refs/heads/$name"; then
      # branch outlived its worktree (clean exit kept committed work), so re-attach it
      git -C "$main" worktree add "$wt" "$name" || return
      made_wt=1
    elif [[ -n "$pr" ]]; then
      # github serves PR heads at the pull/<n>/head ref
      git -C "$main" fetch origin "pull/$pr/head" || return
      git -C "$main" worktree add "$wt" -b "$name" FETCH_HEAD || return
      made_wt=1; made_branch=1
    else
      git -C "$main" worktree add "$wt" -b "$name" || return
      made_wt=1; made_branch=1
    fi
  fi

  # plain claude, not --continue: with nothing to resume (e.g. after :kill-window)
  # --continue exits at once and the chained cleanup would then nuke the worktree.
  tmux new-window -c "$wt" -n "cct:$name" "zsh -ic 'claude --effort max; _cct_cleanup'" || {
    [[ -n "$made_wt" ]] && git -C "$main" worktree remove --force "$wt"
    [[ -n "$made_branch" ]] && git -C "$main" branch -D "$name"
    return 1
  }
}
