# Git shortcuts and worktree helpers for the interactive shell.
#
# The short aliases cover frequent status/diff/stash/add commands. The custom
# functions below add default-branch checkout/rebase helpers, fzf-driven
# worktree creation/removal, and current-branch pull/push wrappers. Destructive
# worktree removal asks for confirmation before deleting the side worktree.

alias gs="git status"
alias gd="git diff"
alias glo="git log --pretty --oneline -5"
# list 10 most recent branches with commit dates
alias gbr="git for-each-ref --sort=-committerdate refs/heads/ --format='%(committerdate:short) %(refname:short)' --count=10"

alias gst="git stash"
alias gstp="git stash pop"

alias ga="git add"
alias gaa="git add ."
alias gau="git restore --staged ."

alias gco="git checkout"
alias gcof="git checkout -f && git clean -df"

# git checkout <default-branch>
gcom() {
  local target

  target=$(git symbolic-ref --quiet refs/remotes/origin/HEAD) || {
    echo "gcom: origin/HEAD is not set for this repo" >&2
    return 1
  }

  git checkout "${target#refs/remotes/origin/}"
}

# git rebase <default-branch>
grb() {
  local target

  target=$(git symbolic-ref --quiet refs/remotes/origin/HEAD) || {
    echo "grb: origin/HEAD is not set for this repo" >&2
    return 1
  }

  git rebase "$target"
}

# ../<project>-<branch> anchored to the main worktree, so it works from inside
# any worktree (show-toplevel would nest paths)
_gwt_target_dir() {
  local main
  main=$(git worktree list --porcelain | awk '/^worktree /{print substr($0, 10); exit}')
  [[ -n "$main" ]] || return 1
  print -r -- "${main:h}/${main:t}-${1//\//-}"
}

_gwt_path_is_within() {
  local child="$1" parent="$2"

  [[ -n "$child" && -n "$parent" && "$child" != "<no value>" ]] || return 1
  child=${child:A}
  parent=${parent:A}
  [[ "$child" == "$parent" || "$child" == "$parent"/* ]]
}

# one inspect per container (not per-field): -aq scans every container, so
# separate inspects per field would be too chatty
_gwt_docker_containers() {
  local target="$1" target_abs id working_dir config_files project state name source match
  local -a ids lines mounts

  command -v docker >/dev/null 2>&1 || return 0
  target_abs=${target:A}
  ids=("${(@f)$(docker ps -aq 2>/dev/null)}")
  [[ -n "${ids[1]}" ]] || return 0

  # name last of the fixed fields: it is always non-empty, so trailing-newline
  # stripping in $() can't drop it and shift the field offsets
  local fmt='{{index .Config.Labels "com.docker.compose.project.working_dir"}}
{{index .Config.Labels "com.docker.compose.project.config_files"}}
{{index .Config.Labels "com.docker.compose.project"}}
{{.State.Status}}
{{.Name}}
{{range .Mounts}}{{if eq .Type "bind"}}{{.Source}}
{{end}}{{end}}'

  for id in "${ids[@]}"; do
    lines=("${(@f)$(docker inspect --format "$fmt" "$id" 2>/dev/null)}")
    (( ${#lines} >= 5 )) || continue
    working_dir=${lines[1]}
    config_files=${lines[2]}
    project=${lines[3]}
    state=${lines[4]}
    name=${lines[5]#/}
    mounts=("${(@)lines[6,-1]}")

    match=0
    if _gwt_path_is_within "$working_dir" "$target_abs"; then
      match=1
    fi

    if (( ! match )); then
      for source in "${(s:,:)config_files}"; do
        if _gwt_path_is_within "$source" "$target_abs"; then
          match=1
          break
        fi
      done
    fi

    if (( ! match )); then
      for source in "${mounts[@]}"; do
        if _gwt_path_is_within "$source" "$target_abs"; then
          match=1
          break
        fi
      done
    fi

    if (( match )); then
      print -r -- "$id"$'\t'"$state"$'\t'"$name"$'\t'"$project"
    fi
  done
}

# git fetch origin <branch> && git worktree add --track -b <branch> ../<project>-<branch> origin/<branch>
gwta() {
  local branch="$1" target_dir

  if [[ -z "$branch" ]]; then
    git fetch --prune origin || return
    # %(if)%(symref): origin/HEAD shortens to bare "origin", a grep on HEAD misses it.
    # awk drops branches already checked out somewhere, worktree add refuses those
    branch=$(git for-each-ref --sort=-committerdate --count=20 \
      --format='%(if)%(symref)%(then)%(else)%(refname:short) %(committerdate:relative)%(end)' \
      refs/remotes/origin \
      | sed -e '/^$/d' -e 's|^origin/||' \
      | awk 'NR==FNR {if (/^branch refs\/heads\//) skip[substr($0, 19)]=1; next} !skip[$1]' \
          <(git worktree list --porcelain) - \
      | fzf --prompt="worktree> " --header="Select a remote branch" --no-multi) || return
    branch=${branch%% *}
  fi

  target_dir=$(_gwt_target_dir "$branch") || return

  git fetch origin "$branch" || return
  if git show-ref --quiet --verify "refs/heads/$branch"; then
    # branch outlived its worktree (e.g. removal kept it), re-attach instead of failing on -b
    git worktree add "$target_dir" "$branch" || return
  else
    git worktree add --track -b "$branch" "$target_dir" "origin/$branch" || return
  fi
  cd "$target_dir"
}

# git worktree add -b <branch> ../<project>-<branch> <default-branch>
gwtn() {
  local branch="$1" base target_dir

  if [[ -z "$branch" ]]; then
    read "branch?new branch name: " || return
    [[ -z "$branch" ]] && return 1
  fi

  # full ref, not --short: a stray local branch named origin/<x> makes the
  # short name ambiguous and git returns remotes/origin/<x> instead
  base=$(git symbolic-ref --quiet refs/remotes/origin/HEAD) || {
    echo "gwtn: origin/HEAD is not set for this repo" >&2
    return 1
  }

  target_dir=$(_gwt_target_dir "$branch") || return

  # branching from stale origin/HEAD invites avoidable rebases
  git fetch origin "${base#refs/remotes/origin/}" || return
  git worktree add --no-track -b "$branch" "$target_dir" "$base" || return
  cd "$target_dir"
}

# tear down matching Docker containers/volumes/networks, then git worktree remove -f <path> && git branch -D <branch>
gwtr() {
  local sel branch target_dir main_worktree cur prompt line rest container_id container_name container_state container_project proj pid
  local -a docker_containers docker_container_ids docker_projects docker_volumes docker_networks vols nets host_pids

  # first thing: daemon down is indistinguishable from "no containers" later,
  # which once let leftovers survive teardown silently
  if command -v docker >/dev/null 2>&1 && ! docker ps -aq >/dev/null 2>&1; then
    echo "gwtr: warning: Docker daemon unreachable, cannot check for leftover containers" >&2
    if ! read -q "REPLY?Continue without the Docker check? [y/N] "; then
      echo
      echo "Cancelled."
      return 1
    fi
    echo
  fi

  main_worktree=$(git worktree list --porcelain | awk '/^worktree /{print substr($0, 10); exit}') || return

  # ask git for paths
  sel=$(git worktree list --porcelain | awk -v main="$main_worktree" '
    /^worktree /{wt=substr($0, 10)}
    /^branch /{br=$0; sub(/^branch refs\/heads\//, "", br); if (wt != main) print br "\t" wt}')

  cur=$(git rev-parse --show-toplevel 2>/dev/null)

  if [[ -n "$1" ]]; then
    sel=$(print -r -- "$sel" | awk -F'\t' -v b="$1" '$1 == b {print; exit}')
    if [[ -z "$sel" ]]; then
      echo "gwtr: no worktree for branch $1" >&2
      return 1
    fi
  elif [[ -n "$cur" && "${cur:A}" != "${main_worktree:A}" ]]; then
    # standing in a side worktree: that's the one to remove, skip the picker
    sel=$(print -r -- "$sel" | awk -F'\t' -v p="$cur" '$2 == p {print; exit}')
    if [[ -z "$sel" ]]; then
      echo "gwtr: current worktree has no branch (detached?)" >&2
      return 1
    fi
  else
    sel=$(print -r -- "$sel" \
      | fzf --prompt="remove worktree> " --header="Select a worktree to remove" --no-multi) || return
  fi

  branch=${sel%%$'\t'*}
  target_dir=${sel#*$'\t'}

  docker_containers=("${(@f)$(_gwt_docker_containers "$target_dir")}")
  [[ -n "${docker_containers[1]}" ]] || docker_containers=()
  if ((${#docker_containers})); then
    echo "gwtr: warning: Docker resources found for $target_dir:" >&2
    for line in "${docker_containers[@]}"; do
      container_id=${line%%$'\t'*}
      rest=${line#*$'\t'}
      container_state=${rest%%$'\t'*}
      rest=${rest#*$'\t'}
      container_name=${rest%%$'\t'*}
      container_project=${rest##*$'\t'}
      docker_container_ids+=("$container_id")
      [[ -n "$container_project" ]] && docker_projects+=("$container_project")
      echo "  $container_name (${container_id[1,12]}) [$container_state]" >&2
    done
    # named volumes/networks aren't bound to a path; reach them via the compose
    # project of the matched containers
    docker_projects=("${(@u)docker_projects}")
    for proj in "${docker_projects[@]}"; do
      vols=("${(@f)$(docker volume ls -q --filter "label=com.docker.compose.project=$proj" 2>/dev/null)}")
      [[ -n "${vols[1]}" ]] && docker_volumes+=("${vols[@]}")
      nets=("${(@f)$(docker network ls -q --filter "label=com.docker.compose.project=$proj" 2>/dev/null)}")
      [[ -n "${nets[1]}" ]] && docker_networks+=("${nets[@]}")
    done
    docker_volumes=("${(@u)docker_volumes}")
    docker_networks=("${(@u)docker_networks}")
    (( ${#docker_volumes} + ${#docker_networks} )) \
      && echo "  + ${#docker_volumes} volume(s), ${#docker_networks} network(s)" >&2
  elif command -v docker >/dev/null 2>&1; then
    # say so even on no match: silence must mean the check didn't run
    echo "gwtr: no Docker resources found for $target_dir" >&2
  fi

  # host processes (sandbox `up`, editors, watchers) aren't docker's problem:
  # after removal they'd run against deleted paths and squat ports until reboot.
  # pgrep -f matches argv; escape dots, the only regex meta these paths carry
  host_pids=("${(@f)$(pgrep -f -- "${target_dir//./\\.}" 2>/dev/null)}")
  [[ -n "${host_pids[1]}" ]] || host_pids=()
  if ((${#host_pids})); then
    echo "gwtr: warning: host processes referencing $target_dir:" >&2
    ps -o pid=,command= -p "${(j:,:)host_pids}" 2>/dev/null | cut -c1-110 | sed 's/^/  /' >&2
  else
    echo "gwtr: no host processes referencing $target_dir" >&2
  fi

  prompt="Remove worktree $target_dir and delete branch $branch"
  ((${#docker_container_ids})) && prompt+=" + ${#docker_container_ids} container(s)"
  ((${#docker_volumes})) && prompt+=" + ${#docker_volumes} volume(s) [DATA LOSS]"
  ((${#docker_networks})) && prompt+=" + ${#docker_networks} network(s)"
  ((${#host_pids})) && prompt+=" + kill ${#host_pids} host process(es)"
  prompt+="? [y/N] "

  if ! read -q "REPLY?$prompt"; then
    echo
    echo "Cancelled."
    return 1
  fi
  echo

  # can't remove worktree we're standing in; :A for symlink-safe compare
  if [[ "${PWD:A}/" == "${target_dir:A}/"* ]]; then
    cd "$main_worktree" || return
  fi

  if ((${#host_pids})); then
    kill "${host_pids[@]}" 2>/dev/null
    sleep 1
    # TERM first is manners; anything still alive gets the hammer
    for pid in "${host_pids[@]}"; do
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
    done
  fi

  if ((${#docker_container_ids})); then
    docker rm -fv "${docker_container_ids[@]}" || return
    # best-effort: volume/network rm fails non-fatally if still used elsewhere
    ((${#docker_volumes})) && docker volume rm "${docker_volumes[@]}" 2>/dev/null
    ((${#docker_networks})) && docker network rm "${docker_networks[@]}" 2>/dev/null
  fi

  if ! git worktree remove -f "$target_dir"; then
    # Finder races a fresh .DS_Store into the emptying dir -> "Directory not
    # empty" on the final rmdir. Sweep junk + empty dirs; anything else = bail
    if [[ -d "$target_dir" ]]; then
      find "$target_dir" -name '.DS_Store' -delete 2>/dev/null
      find "$target_dir" -type d -empty -delete 2>/dev/null
      if [[ -d "$target_dir" ]]; then
        echo "gwtr: $target_dir still not empty after junk sweep - inspect it" >&2
        return 1
      fi
    fi
    git worktree prune
  fi
  # -D: delete already confirmed above, -d would strand unmerged branches
  git branch -D "$branch"
}

# git commit -m "<message>"
gcm() {
  if [ $# -eq 0 ]; then
    echo "usage: gcm <message>" >&2
    return 1
  fi
  git commit -m "$*"
}

# git pull origin <current-branch>
gpl() {
  local br
  br=$(git symbolic-ref --short HEAD) || return
  git pull origin "$br"
}

# git push origin <current-branch>
gpu() {
  local br
  br=$(git symbolic-ref --short HEAD) || return
  git push origin "$br"
}

# git push origin <current-branch> --force-with-lease
gpuf() {
  local br
  br=$(git symbolic-ref --short HEAD) || return
  git push origin "$br" --force-with-lease
}

# git reset --soft HEAD~1 (undo last commit, keep changes staged)
gundo() {
  git reset --soft HEAD~1
}

# git show --format= <commit> | pbcopy
gdc() {
  if [ $# -eq 0 ]; then
    echo "usage: gdc <commit>" >&2
    return 1
  fi
  git show --format= "$1" | pbcopy
}
