# Ignore Apple-specific SSH options on non-macOS OpenSSH builds.
IgnoreUnknown UseKeychain

# Apply to all hosts
Host *
  AddKeysToAgent yes
  UseKeychain yes

# GitHub
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/github
  IdentitiesOnly yes

# Bitbucket
Host bitbucket.org
  HostName bitbucket.org
  User git
  IdentityFile ~/.ssh/bitbucket
  IdentitiesOnly yes
