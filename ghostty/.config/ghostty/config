window-save-state = "always"
macos-option-as-alt = true
confirm-close-surface = false

theme = light:Flexoki Light,dark:TokyoNight Storm
# Manual override; theme-toggle.sh writes `theme = Flexoki Light` or `theme = TokyoNight Storm`
# here to force one regardless of macOS appearance. Missing file = follow macOS.
# Lives outside the stowed config dir so it isn't tracked by git.
config-file = ?~/.cache/dotfiles/ghostty-theme-active.conf

# Next/previous pane
keybind = cmd+k=goto_split:next
keybind = cmd+j=goto_split:previous

# Previous/next tmux window (sends Ctrl+P / Ctrl+N to tmux)
keybind = cmd+shift+[=text:\x10
keybind = cmd+shift+]=text:\x0e

# Inserts a new line for multi-line prompts without immediately running the command
keybind = shift+enter=text:\x1b\r

# Enable OSC 52 clipboard support for SSH
clipboard-read = allow
clipboard-write = allow

# Preserve Ghostty terminfo through sudo and prefer native remote terminfo over TERM fallbacks.
shell-integration-features = sudo,ssh-terminfo,ssh-env
