alias y="yazi"
cc() {
  if [[ $# -eq 0 ]]; then
    claude
  elif [[ "$1" == -* ]]; then
    claude "$@"
  else
    claude -n "$*"
  fi
}
alias cx="codex"
alias co="copilot"

alias lg="lazygit"
alias ld="lazydocker"

alias cl="clear"
alias ex="exit"
alias ff="fastfetch"
alias ls="eza --group-directories-first"
alias ll="eza --group-directories-first --all -lh"
alias lt="eza --group-directories-first --tree --level=2 --icons"
alias lti="eza --group-directories-first --all --tree --icons"
vim() {
  if [[ $# -gt 0 ]]; then
    nvim "$@"
  else
    nvim .
  fi
}

alias ip="ipconfig getifaddr en0"
# Copy the last command to clipboard
alias cp1="fc -ln -1 | awk '{\$1=\$1;print}' | pbcopy"
alias txp="tmuxp load -y"
alias txl="tmux ls"
alias src="source ~/.zshrc"
alias vrc="vim ~/.zshrc"
alias vrch="vim ~/.zsh_history"
alias vrca="vim ~/.zsh_aliases"

TMUX_DEFAULT_SESSION="${TMUX_DEFAULT_SESSION:-tmp}"

tx() {
  if [[ -n "$1" ]]; then
    tmux new -A -s "$1"
  else
    tmux new -A -s "$TMUX_DEFAULT_SESSION"
  fi
}

txk() {
  tmux kill-session -t "${1:-$TMUX_DEFAULT_SESSION}"
}

[[ -f "${${(%):-%N}:A:h}/.zsh_git_aliases" ]] && source "${${(%):-%N}:A:h}/.zsh_git_aliases"

# Tailscale File Send
# Usage: fsend <machine_name> <file1> [file2 ...]
fsend() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: fsend <machine_name> <file1> [file2 ...]"
    return 1
  fi

  local machine="$1"
  shift  # Remove machine from args, leaving only files

  # Tailscale requires a trailing colon after the machine name/IP
  tailscale file cp "$@" "${machine}:"
}

# Tailscale File Get
# Usage: fget [destination_directory]
fget() {
  # Defaults to ~/Downloads/ if no destination is provided
  local dest="${1:-$HOME/Downloads/}"

  echo "Pulling waiting Tailscale files into $dest..."
  tailscale file get "$dest"
}

ltail() {
  if [ $# -eq 0 ]; then
    echo "Usage: ltail <file_or_directory>"
    return 1
  fi
  lnav "$@"
}
