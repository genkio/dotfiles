in_vm = `/usr/sbin/sysctl -n kern.hv_vmm_present 2>/dev/null`.strip == "1" ||
        `/usr/sbin/sysctl -n hw.model 2>/dev/null`.strip.match?(/VirtualMac|VMware|Parallels|QEMU/i)

brew "awscli"
brew "gh"
brew "git-delta"
brew "gnupg"
brew "lazydocker" unless in_vm
brew "lazygit"
brew "lazysql"
brew "mise"

cask "alacritty"
cask "codex"
cask "orbstack" unless in_vm
