alias y="yazi"
cc() {
  if [[ $# -eq 0 ]]; then
    claude
  elif [[ "$1" == -* ]]; then
    claude "$@"
  else
    claude -n "$*"
  fi
}
alias cx="codex"
alias co="copilot"

alias lg="lazygit"
alias ld="lazydocker"

zip() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: zip <file-or-folder>"
    return 1
  fi

  local src="${1:A}"
  if [[ ! -e "$src" ]]; then
    echo "zip: path not found: $1"
    return 1
  fi

  local sevenzip="${commands[7zz]:-${commands[7z]}}"
  if [[ -z "$sevenzip" ]]; then
    echo "zip: 7-Zip executable not found"
    return 127
  fi

  local parent="${src:h}"
  local entry="${src:t}"
  local archive="${parent}/${entry}.zip"
  local -a excludes=(
    '-xr!__MACOSX'
    '-xr!.DS_Store'
    '-xr!._*'
    '-xr!.AppleDouble'
    '-xr!.Spotlight-V100'
    '-xr!.Trashes'
    '-xr!.fseventsd'
  )

  if [[ -e "$archive" ]]; then
    echo "zip: archive already exists: $archive"
    return 1
  fi

  (
    cd "$parent" || return
    "$sevenzip" a -tzip -mx=0 "$archive" "$entry" "${excludes[@]}"
  ) || return

  if ! osascript \
    -e 'on run argv' \
    -e 'set trashTarget to POSIX file (item 1 of argv) as alias' \
    -e 'tell application "Finder" to delete trashTarget' \
    -e 'end run' \
    "$src"; then
    echo "zip: archive created but failed to move to Trash: $src"
    return 1
  fi
}

_unzip_archive() {
  local sevenzip="$1"
  local src="${2:A}"
  local parent="${src:h}"
  local entry="${src:t}"
  local base="${entry:r}"

  if [[ ! -f "$src" ]]; then
    echo "unzip: not a file: $src"
    return 1
  fi

  if [[ "${entry:l}" != *.zip ]]; then
    echo "unzip: expected a .zip file: $src"
    return 1
  fi

  local dest="${parent}/${base}"
  if [[ -e "$dest" ]]; then
    echo "unzip: destination already exists: $dest"
    return 1
  fi

  mkdir "$dest" || return
  "$sevenzip" x "$src" "-o$dest" || return
}

unzip() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: unzip <zip-file-or-folder>"
    return 1
  fi

  local src="${1:A}"
  if [[ ! -e "$src" ]]; then
    echo "unzip: path not found: $1"
    return 1
  fi

  local sevenzip="${commands[7zz]:-${commands[7z]}}"
  if [[ -z "$sevenzip" ]]; then
    echo "unzip: 7-Zip executable not found"
    return 127
  fi

  if [[ -d "$src" ]]; then
    local -a raw_archives archives
    local -A seen
    local archive

    raw_archives=("$src"/*.zip(N) "$src"/*.ZIP(N))
    for archive in "${raw_archives[@]}"; do
      [[ -n "${seen[$archive]}" ]] && continue
      seen[$archive]=1
      archives+=("$archive")
    done

    if [[ ${#archives[@]} -eq 0 ]]; then
      echo "unzip: no .zip files found in folder: $1"
      return 1
    fi

    for archive in "${archives[@]}"; do
      _unzip_archive "$sevenzip" "$archive" || return
    done
    return
  fi

  _unzip_archive "$sevenzip" "$src"
}

alias cl="clear"
alias ex="exit"
alias ff="fastfetch"
alias ls="eza --group-directories-first"
alias ll="eza --group-directories-first --all -lh"
alias lt="eza --group-directories-first --tree --level=2 --icons"
alias lti="eza --group-directories-first --all --tree --icons"
vim() {
  if [[ $# -gt 0 ]]; then
    nvim "$@"
  else
    nvim .
  fi
}

alias ip="ipconfig getifaddr en0"

killport() {
  if [[ $# -ne 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: killport <port>"
    return 1
  fi

  local port="$1"
  if [[ "$port" != <-> || port -lt 1 || port -gt 65535 ]]; then
    echo "killport: invalid port: $port"
    return 1
  fi

  local output
  output="$(lsof -nP -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null)"
  if [[ -z "$output" ]]; then
    echo "killport: no process listening on port $port"
    return 1
  fi

  local -a pids
  pids=("${(@f)output}")
  kill "${pids[@]}" || return

  echo "killport: sent TERM to PID(s): ${pids[*]}"
}

kip() {
  killport "$@"
}

# Copy the last command to clipboard
alias cp1="fc -ln -1 | awk '{\$1=\$1;print}' | pbcopy"
alias txp="tmuxp load -y"
alias txl="tmux ls"
alias src="source ~/.zshrc"
alias vrc="vim ~/.zshrc"
alias vrch="vim ~/.zsh_history"
alias vrca="vim ~/.zsh_aliases"

TMUX_DEFAULT_SESSION="${TMUX_DEFAULT_SESSION:-tmp}"

tx() {
  if [[ -n "$1" ]]; then
    tmux new -A -s "$1"
  else
    tmux new -A -s "$TMUX_DEFAULT_SESSION"
  fi
}

txk() {
  tmux kill-session -t "${1:-$TMUX_DEFAULT_SESSION}"
}

[[ -f "${${(%):-%N}:A:h}/.zsh_git_aliases" ]] && source "${${(%):-%N}:A:h}/.zsh_git_aliases"

# Tailscale File Send
# Usage: fsend <machine_name> <file1> [file2 ...]
fsend() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: fsend <machine_name> <file1> [file2 ...]"
    return 1
  fi

  local machine="$1"
  shift  # Remove machine from args, leaving only files

  # Tailscale requires a trailing colon after the machine name/IP
  tailscale file cp "$@" "${machine}:"
}

# Tailscale File Get
# Usage: fget [destination_directory]
fget() {
  # Defaults to ~/Downloads/ if no destination is provided
  local dest="${1:-$HOME/Downloads/}"

  echo "Pulling waiting Tailscale files into $dest..."
  tailscale file get "$dest"
}

ltail() {
  if [ $# -eq 0 ]; then
    echo "Usage: ltail <file_or_directory>"
    return 1
  fi
  lnav "$@"
}
