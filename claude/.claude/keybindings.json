{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Transcript",
      "bindings": {
        "shift+j": "scroll:bottom",
        "shift+k": "scroll:top",
        "shift+u": "scroll:halfPageUp",
        "shift+d": "scroll:halfPageDown"
      }
    }
  ]
}
