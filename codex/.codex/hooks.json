{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-busy.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook --agent codex --event UserPromptSubmit || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-busy.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook --agent codex --event PreToolUse || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-attention.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook --agent codex --event PermissionRequest || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/tmux/bin/agent-idle.sh"
          },
          {
            "type": "command",
            "command": "command -v herdlet >/dev/null 2>&1 && herdlet hook --agent codex --event Stop || true"
          }
        ]
      }
    ]
  }
}
